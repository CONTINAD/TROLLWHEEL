# --- Solana RPC ---
# Use a paid RPC (Helius / QuickNode / Triton). Free RPCs disable
# getProgramAccounts which is required for snapshotting holders.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# --- Wallets ---
# CREATOR_WALLET = the pump.fun creator wallet for $TROLLWHEEL. Claims fees.
CREATOR_WALLET_PRIVATE_KEY=base58_secret_key
# Optional: separate buyer wallet. Leave blank to use the creator wallet for
# both roles (single-wallet mode).
# BUYER_WALLET_PRIVATE_KEY=base58_secret_key

# --- Tokens ---
# Leave TROLLWHEEL_MINT=auto to have the bot watch the creator wallet and
# adopt whichever pump.fun token it launches next.
TROLLWHEEL_MINT=auto
MINT_WATCH_POLL_SECONDS=20
# Mint of the meme being bought back with creator fees.
TROLL_MINT=5UUH9RTDiSpq6HKS6bp4NdU9PNJpXRXuiw6ShBTBhgH2

# --- PumpPortal (https://pumpportal.fun) ---
# Optional Lightning API key for server-side signing. Leave blank for local signing.
PUMPPORTAL_API_KEY=

# --- Cycle settings ---
CYCLE_INTERVAL_SECONDS=300           # 5 min per cycle
MIN_BUYBACK_SOL=0.01                 # skip cycle if spendable falls below this
BUYBACK_PERCENT=90                   # % of claimed fees the bot may spend
MAX_SLIPPAGE=15                      # PumpPortal slippage %
PRIORITY_FEE=0.0005                  # SOL of priority fee on each buy

# --- Distribution settings ---
# % of each cycle's bought $TROLL that gets distributed. The rest is kept in
# the buyer wallet as a permanent treasury that compounds.
DISTRIBUTE_PERCENT=80
MIN_HOLDER_BALANCE=1                 # ignore wallets with < this many $TROLLWHEEL
# Comma-separated wallets to skip. ALWAYS include the LP / bonding curve
# (it's the majority holder) and your dev/creator wallet (never send to self).
EXCLUDE_WALLETS=
HOP_COUNT=1                          # # of throwaway wallets between buyer and holder
HOP_FUND_LAMPORTS=3000000            # lamports seeded into each hop (recovered via close+sweep)
MAX_HOLDERS_PER_CYCLE=500            # max holders to distribute to per cycle
DISTRIBUTION_CONCURRENCY=5           # parallel holder chains (1–8)

# --- State persistence ---
# On Railway / any host with a persistent volume, point this at the volume
# mount path (e.g. /data). Falls back to ./data locally.
# STATE_DIR=/data

# --- Dashboard ---
PORT=3000
LOG_LEVEL=info
